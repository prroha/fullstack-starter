{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["../../core/web/src/*"],
      "@preview/*": ["./src/*"],

      "@/lib/ecommerce/*": ["../../modules/ecommerce/web/src/lib/ecommerce/*"],
      "@/lib/lms/*": ["../../modules/lms/web/src/lib/lms/*"],
      "@/lib/booking/*": ["../../modules/booking/web/src/lib/booking/*"],
      "@/lib/helpdesk/*": ["../../modules/helpdesk/web/src/lib/helpdesk/*"],
      "@/lib/invoicing/*": ["../../modules/invoicing/web/src/lib/invoicing/*"],
      "@/lib/events/*": ["../../modules/events/web/src/lib/events/*"],
      "@/lib/tasks/*": ["../../modules/tasks/web/src/lib/tasks/*"],

      "@/components/ecommerce/*": [
        "../../modules/ecommerce/web/src/components/ecommerce/*"
      ],
      "@/components/lms/*": ["../../modules/lms/web/src/components/lms/*"],
      "@/components/booking/*": [
        "../../modules/booking/web/src/components/booking/*"
      ],
      "@/components/helpdesk/*": [
        "../../modules/helpdesk/web/src/components/helpdesk/*"
      ],
      "@/components/invoicing/*": [
        "../../modules/invoicing/web/src/components/invoicing/*"
      ],
      "@/components/events/*": [
        "../../modules/events/web/src/components/events/*"
      ],
      "@/components/tasks/*": ["../../modules/tasks/web/src/components/tasks/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../modules/*/web/src/**/*.ts",
    "../../modules/*/web/src/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
