  slug        String
  description String?
  type        EventType   @default(IN_PERSON)
  status      EventStatus @default(DRAFT)
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  capacity    Int?
  price       Int         @default(0)
  currency    String      @default("USD")
  imageUrl    String?     @map("image_url")
  isFeatured  Boolean     @default(false) @map("is_featured")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  category      EventCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  venue         EventVenue?        @relation(fields: [venueId], references: [id], onDelete: SetNull)
  registrations EventRegistration[]
  speakers      EventSpeaker[]

  @@index([userId])
  @@index([categoryId])
  @@index([venueId])
  @@index([status])
  @@index([startDate])
  @@map("events_events")
}

// From: events
model EventRegistration {
  id                 String             @id @default(uuid())
  eventId            String             @map("event_id")
  userId             String             @map("user_id")
  status             RegistrationStatus @default(PENDING)
  registrationNumber String             @unique @map("registration_number")
  attendeeName       String             @map("attendee_name")
  attendeeEmail      String             @map("attendee_email")
  notes              String?
  checkedInAt        DateTime?          @map("checked_in_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("events_registrations")
}

// From: events
model EventSpeaker {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  name      String
  email     String?
  bio       String?
  avatarUrl String?  @map("avatar_url")
  title     String?
  company   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("events_speakers")
}

// From: events
model EventSettings {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  defaultView       String   @default("LIST") @map("default_view")
  defaultCategoryId String?  @map("default_category_id")
  currency          String   @default("USD")
  timezone          String   @default("UTC")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("events_settings")
}

// From: tasks
enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

// From: tasks
enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

// From: tasks
enum TaskView {
  LIST
  BOARD
  CALENDAR
}

// From: tasks
model TaskProject {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  color       String   @default("#6B7280")
  icon        String?
  isArchived  Boolean  @default(false) @map("is_archived")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@index([userId])
  @@map("tasks_projects")
}

// From: tasks
model Task {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  projectId   String?      @map("project_id")
  assigneeId  String?      @map("assignee_id")
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(NONE)
  dueDate     DateTime?    @map("due_date")
  position    Int          @default(0)
  isArchived  Boolean      @default(false) @map("is_archived")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project  TaskProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  comments TaskComment[]
  labels   TaskLabelLink[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@map("tasks_tasks")
}

// From: tasks
model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("tasks_comments")
}

// From: tasks
model TaskLabel {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now()) @map("created_at")

  tasks TaskLabelLink[]

  @@index([userId])
  @@map("tasks_labels")
}

// From: tasks
model TaskLabelLink {
  id      String @id @default(uuid())
  taskId  String @map("task_id")
  labelId String @map("label_id")

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@map("tasks_task_labels")
}

// From: tasks
model TaskSettings {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  defaultView        TaskView @default(LIST) @map("default_view")
  defaultProjectId   String?  @map("default_project_id")
  showCompletedTasks Boolean  @default(true) @map("show_completed_tasks")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("tasks_settings")
}